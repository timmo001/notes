{
  "name": "notes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "notes": "./dist/notes",
    "note": "./dist/notes",
    "handoffs": "./dist/notes",
    "handoff": "./dist/notes"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/notes",
    "test": "bun test",
    "format": "prettier --write \"{src,tests}/**/*.ts\" \"docs/astro.config.mjs\" \"docs/scripts/**/*.{ts,mjs}\" \"docs/src/**/*.{md,mdx,astro,css}\"",
    "format:check": "prettier --check \"{src,tests}/**/*.ts\" \"docs/astro.config.mjs\" \"docs/scripts/**/*.{ts,mjs}\" \"docs/src/**/*.{md,mdx,astro,css}\"",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@effect/platform-node": "^4.0.0-beta.93",
    "@opentui/core": "^0.4.3",
    "effect": "^4.0.0-beta.93",
    "fuse.js": "^7.4.2",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.87.0",
    "@types/bun": "^1.3.13",
    "@types/proper-lockfile": "^4.1.4",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@effect/language-service"
  ]
}
