---
import type { RepositoryOption } from "../capture/repositories.js";

interface Props {
  repositories: readonly RepositoryOption[] | undefined;
  defaultRepository: string;
}

const { repositories, defaultRepository } = Astro.props;
const defaultOption =
  repositories?.find(({ repository }) => repository === defaultRepository) ??
  repositories?.[0];
---

<main>
  <header>
    <h1>Capture a note</h1>
    <p>Type or dictate a note. It will be added to your notes repository.</p>
  </header>

  <form data-capture-form>
    <div class="capture-field">
      <label class="sr-only" for="capture">Note</label>
      <textarea
        id="capture"
        name="capture"
        rows="10"
        maxlength="12000"
        required
        autofocus
        placeholder="Write a note..."></textarea>
      <button
        class="record"
        type="button"
        data-record
        hidden
        aria-label="Start dictation"
        title="Start dictation"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 14a3 3 0 0 0 3-3V5a3 3 0 1 0-6 0v6a3 3 0 0 0 3 3Z"
          ></path>
          <path d="M19 11a7 7 0 0 1-14 0M12 18v3M9 21h6"></path>
        </svg>
      </button>
    </div>

    {
      repositories && defaultOption && (
        <div class="repository-picker" data-repository-picker>
          <input
            type="hidden"
            name="repository"
            value={defaultOption.repository}
            data-repository-value
          />
          <button
            class="repository-trigger"
            type="button"
            popovertarget="repository-popover"
            aria-label={`Repository: ${defaultOption.label}`}
            data-repository-trigger
          >
            <span data-repository-label>{defaultOption.label}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m7 10 5 5 5-5" />
            </svg>
          </button>
          <div
            class="repository-popover"
            id="repository-popover"
            popover="auto"
            data-repository-popover
          >
            <label class="sr-only" for="repository-search">
              Search repositories
            </label>
            <input
              class="repository-search"
              id="repository-search"
              type="search"
              placeholder="Search repositories..."
              autocomplete="off"
              data-repository-search
            />
            <div class="repository-options" data-repository-options>
              {repositories.map((option) => (
                <button
                  class="repository-option"
                  type="button"
                  data-repository-option={option.repository}
                  data-repository-search-text={`${option.label} ${option.repository}`}
                  aria-pressed={
                    option.repository === defaultOption.repository
                      ? "true"
                      : "false"
                  }
                >
                  <span>{option.label}</span>
                  <small>{option.repository}</small>
                </button>
              ))}
            </div>
            <p class="repository-empty" data-repository-empty hidden>
              No matching repositories
            </p>
          </div>
        </div>
      )
    }

    <p class="status" data-status role="status" aria-live="polite"></p>
    <button class="submit" type="submit">Add note</button>
  </form>
</main>

<script>
  import "../scripts/capture.js";
</script>
